<Window x:Class="DancingBarsWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Танцюючі прогрес-бари" Height="450" Width="400">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Кількість барів:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <TextBox x:Name="CountTextBox" Text="5" Width="50" Padding="2" VerticalContentAlignment="Center"/>
            <Button Content="Старт" Width="100" Margin="15,0,0,0" Click="StartButton_Click"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="BarsContainer" Orientation="Vertical"/>
        </ScrollViewer>
    </Grid>
</Window>